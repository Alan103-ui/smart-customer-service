# ============ 依赖 ============
node_modules/
package-lock.json
# 例外：server 的 lockfile 需入库，供 CI 用 npm ci 确定性安装（避免 CI 因缺 lockfile 失败）
!server/package-lock.json
yarn.lock
pnpm-lock.yaml

# ============ 构建产物 ============
dist/
build/
client/dist/
server/public/assets/
server/public/index.html
server/public/*.js
server/public/*.css

# ============ 环境配置 ============
.env
.<EMAIL>
*.local

# ============ 日志 ============
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============ 系统文件 ============
.DS_Store
Thumbs.db
desktop.ini

# ============ 守护进程锁文件 ============
.daemon.pid

# ============ IDE ============
.vscode/
.idea/
*.swp
*.swo
*~

# ============ 项目特定 ============
server/uploads/
*.bak
*.backup
*.tmp

# ============ 测试覆盖率 ============
coverage/
.nyc_output/

# ============ Jest ============
<EMAIL>/
data/
# 保留系统启动必需的种子/配置（其余 data/*.json 为运行时数据，不入库，避免 checkout 回退用户数据）
!data/users.json
!data/permissions.json
!data/categories.json
!data/knowledge_bases.json
!data/a8_config.json

# ============ 工作区记忆与验证产物 ============
.workbuddy/
scripts/*.png
scripts/dl/

# ============ Windows 保留设备名误建文件 ============
# Git Bash 下 `2>nul` 会误建名为 nul 的文件（Windows 保留设备名），加忽略避免 git add 失败
/nul
