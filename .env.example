# ============ 致远 OA（seeyon / A8）对接配置 ============
# 复制为 .env 后填入真实值（.env 已被 .gitignore 排除，不会入库）
# 若同时配置 OA_TOKEN 与 OA_API_SECRET，系统优先使用 OA_TOKEN（固定令牌）；
# 否则使用 secret 动态获取令牌（推荐，令牌永不过期）。

# 是否启用 OA 对接（1=启用）
OA_ENABLED=1

# 致远 OA 服务地址（到端口，不含 /seeyon）
OA_BASE_URL=http://172.17.6.4:60099

# 调用 REST 接口所用账号（用于动态获取 token）
OA_API_USERNAME=your_oa_username

# 调用 REST 接口所用密钥（与 username 配对，用于动态获取 token）
OA_API_SECRET=your_oa_secret

# 可选：固定令牌（若 OA 分配了长期有效的 rest token，可直接填这里）
OA_TOKEN=optional_fixed_token
